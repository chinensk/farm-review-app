"use client"; 
 
import { useEffect, useState } from "react"; 
import { useParams } from "next/navigation"; 
import { supabase } from "@/lib/supabase"; 
 
export default function CouponPage() { 
  const params = useParams<{ couponId: string }>(); 
  const couponId = params.couponId; 
 
  const [coupon, setCoupon] = useState<any>(null); 
  const [pin, setPin] = useState(""); 
  const [busy, setBusy] = useState(false); 
 
  const load = async () => { 
    const { data, error } = await supabase 
      .from("coupons") 
      .select("id,title,conditions,expires_at,status,store_id,stores(staff_pin)") 
      .or(`id.eq.${couponId},token.eq.${couponId}`) 
      .single(); 
 
    if (error) { 
      alert("クーポンが見つかりません"); 
      return; 
    } 
    setCoupon(data); 
  }; 
 
  useEffect(() => { load(); }, []); 
 
  const redeem = async () => { 
    if (!coupon || coupon.status === "redeemed") return; 
 
    // MVP: PINはクライアントで照合（後でサーバー側に移すとより安全） 
    if (pin !== coupon.stores.staff_pin) { 
      alert("PINが違います"); 
      return; 
    } 
 
    setBusy(true); 
    const { error } = await supabase 
      .from("coupons") 
      .update({ status: "redeemed", redeemed_at: new Date().toISOString() }) 
      .eq("id", couponId); 
 
    if (error) { 
      alert("使用済みにできませんでした"); 
      setBusy(false); 
      return; 
    } 
 
    await supabase.from("events").insert({ 
      store_id: coupon.store_id, 
      coupon_id: couponId, 
      event_name: "coupon_redeemed", 
      meta: {} 
    }); 
 
    await load(); 
    setBusy(false); 
  }; 
 
  if (!coupon) return <div style={{ padding: 16 }}>読み込み中...</div>; 
 
  const exp = new Date(coupon.expires_at); 
 
  return ( 
    <div style={{ maxWidth: 560, margin: "0 auto", padding: 16 }}> 
      <h1 style={{ fontSize: 22 }}>{coupon.title}</h1> 
 
      <div style={{ marginTop: 8, padding: 12, borderRadius: 12, background: "#fff7ed", border: "1px solid #fed7aa" }}> 
        <b>当日限り有効</b>（〜 {exp.toLocaleString()}） 
      </div> 
 
      <h2 style={{ marginTop: 16 }}>利用条件</h2> 
      <pre style={{ whiteSpace: "pre-wrap", background: "#f5f5f5", padding: 12, borderRadius: 12 }}> 
        {coupon.conditions} 
      </pre> 
 
      <div style={{ height: 12 }} /> 
      {coupon.status === "redeemed" ? ( 
        <div style={{ padding: 14, borderRadius: 12, background: "#111", color: "#fff", fontWeight: 900 }}> 
          使用済み 
        </div> 
      ) : ( 
        <> 
          <h2>スタッフ用（PIN）</h2> 
          <input 
            inputMode="numeric" 
            placeholder="4桁PIN" 
            value={pin} 
            onChange={(e)=>setPin(e.target.value)} 
            style={{ width: "100%", padding: 12, fontSize: 16, borderRadius: 12, border: "1px solid #ddd" }} 
          /> 
          <div style={{ height: 10 }} /> 
          <button onClick={redeem} disabled={busy} 
            style={{ width: "100%", padding: 14, borderRadius: 12, border: 0, background: "#f97316", color: "#fff", fontWeight: 900 }}> 
            {busy ? "処理中..." : "使用済みにする"} 
          </button> 
          <p style={{ marginTop: 10, fontSize: 12, color: "#b00" }}> 
            ※PINを入れて「使用済みにする」を押すと、二度と使えません。 
          </p> 
        </> 
      )} 
    </div> 
  ); 
} 